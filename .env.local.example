# Canvas LMS Configuration
CANVAS_DOMAIN=school.instructure.com

# Child 1
CHILD_1_NAME=Max
CHILD_1_TOKEN=your_canvas_api_token_here

# Child 2 (optional — add more with CHILD_3_NAME, CHILD_3_TOKEN, etc.)
CHILD_2_NAME=Lily
CHILD_2_TOKEN=your_canvas_api_token_here

# MCP Server
MCP_TRANSPORT=streamable-http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3001

# Anthropic AI (for homework helper, insights, catch-up)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Simple PIN gate (leave empty to disable)
APP_PIN=
